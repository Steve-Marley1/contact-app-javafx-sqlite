<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.javateam.controller.MainController"
            stylesheets="@style.css"
            prefWidth="1000"
            prefHeight="650">

 
    <top>
        <VBox alignment="CENTER"
              style="-fx-background-color: linear-gradient(to right, #1f3c88, #0f2027);"
              prefHeight="120">
            <Label text="Contact Management Application"
                   style="-fx-font-size: 32px;
                          -fx-text-fill: white;
                          -fx-font-weight: bold;
                          -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0.5, 0, 2);"/>
        </VBox>
    </top>


    <center>
        <VBox VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TableView fx:id="personTable"
                       VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="idColumn" text="ID"/>
                    <TableColumn fx:id="firstnameColumn" text="Firstname"/>
                    <TableColumn fx:id="lastnameColumn" text="Lastname"/>
                    <TableColumn fx:id="nicknameColumn" text="Nickname"/>
                    <TableColumn fx:id="phoneColumn" text="Phone"/>
                    <TableColumn fx:id="emailColumn" text="Email"/>
                    <TableColumn fx:id="addressColumn" text="Address"/>
                    <TableColumn fx:id="birthDateColumn" text="Birth Date"/>
                </columns>

            </TableView>
        </VBox>
    </center>


    <bottom>
        <VBox spacing="20">
            <padding>
                <Insets top="25" bottom="30" left="40" right="40"/>
            </padding>

            <GridPane hgap="25" vgap="20">

                <Label text="Firstname:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="firstnameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Nickname:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="nicknameField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Lastname:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="lastnameField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Phone:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Address:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                <TextField fx:id="addressField" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                <Label text="Birth Date:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <DatePicker fx:id="birthDatePicker"
                            GridPane.rowIndex="3"
                            GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="25" alignment="CENTER">
                <Button text="Add" onAction="#handleAdd" styleClass="btn-add"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="btn-update"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="btn-delete"/>
            </HBox>

        </VBox>
    </bottom>

</BorderPane>